{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "web": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {

        /* ======================================================
           BUILD CONFIG
        ====================================================== */
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",

            "assets": [
              "src/assets",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],

            "styles": [
              "src/styles.css"
            ],

            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },

        /* ======================================================
           SERVE CONFIG (LOCKED TO 4300)
        ====================================================== */
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4300
          },
          "configurations": {
            "production": {
              "buildTarget": "web:build:production",
              "port": 4300
            },
            "development": {
              "buildTarget": "web:build:development",
              "port": 4300
            }
          },
          "defaultConfiguration": "development"
        },

        /* ======================================================
           TEST CONFIG
        ====================================================== */
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
